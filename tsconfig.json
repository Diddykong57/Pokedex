{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es2022",
        "types": ["node", "jest"],

        "sourceMap": true,

        "strict": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
